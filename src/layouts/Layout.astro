---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "AdFunnl — All your ad data in one place. Connect Meta, TikTok, Google Ads, Snapchat and more into one unified dashboard.",
  ogImage = "/logo-1024.png",
} = Astro.props;

const APP_URL = "https://app.adfunnl.com";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <meta property="og:title"       content={`${title} · AdFunnl`} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:type"        content="website" />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={`${title} · AdFunnl`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <title>{title} · AdFunnl</title>
  </head>
  <body class="bg-white text-zinc-900 antialiased font-sans">

    <!-- Nav -->
    <header class="sticky top-0 z-50 border-b border-zinc-100 bg-white/90 backdrop-blur-sm">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/">
          <img src="/logo.png" alt="AdFunnl" class="h-6 w-auto" />
        </a>
        <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-zinc-600">
          <a href="/#features" class="hover:text-zinc-900 transition">Features</a>
          <a href="/#integrations" class="hover:text-zinc-900 transition">Integrations</a>
          <a href="/pricing" class="hover:text-zinc-900 transition">Pricing</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href={`${APP_URL}/login`}
             class="hidden sm:inline-block text-sm font-medium text-zinc-600 hover:text-zinc-900 transition">
            Sign in
          </a>
          <a href={`${APP_URL}/signup`}
             class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700 transition">
            Get started free
          </a>
        </div>
      </div>
    </header>

    <slot />

    <!-- Footer -->
    <footer class="border-t border-zinc-100 bg-zinc-50">
      <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <img src="/logo.png" alt="AdFunnl" class="h-5 w-auto mb-2" />
            <p class="text-sm text-zinc-500">All your ad data in one place.</p>
          </div>
          <nav class="flex flex-wrap gap-6 text-sm text-zinc-500">
            <a href="/#features"     class="hover:text-zinc-900 transition">Features</a>
            <a href="/#integrations" class="hover:text-zinc-900 transition">Integrations</a>
            <a href="/pricing"       class="hover:text-zinc-900 transition">Pricing</a>
            <a href="/privacy"       class="hover:text-zinc-900 transition">Privacy</a>
            <a href="/terms"         class="hover:text-zinc-900 transition">Terms</a>
          </nav>
        </div>
        <div class="mt-8 border-t border-zinc-200 pt-6 text-xs text-zinc-400">
          © {new Date().getFullYear()} AdFunnl. All rights reserved.
        </div>
      </div>
    </footer>

  </body>
</html>
