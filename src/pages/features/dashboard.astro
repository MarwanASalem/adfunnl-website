---
import Layout from "../../layouts/Layout.astro";

const APP_URL = "https://app.adfunnl.com";

const tileTypes = [
  { name: "KPI tiles",        note: "Spend, ROAS, CAC, CTR — any metric, at a glance" },
  { name: "Charts",           note: "Trends, comparisons and breakdowns" },
  { name: "Funnels",          note: "Impression → click → purchase, step by step" },
  { name: "Geo maps",         note: "Performance by country and region" },
  { name: "Tables",           note: "Dense data with conditional rules" },
  { name: "Creative galleries", note: "Full-resolution previews beside performance" },
];

const capabilities = [
  {
    title: "A freeform canvas, not a template",
    body: "Drag any tile anywhere on a whiteboard-style canvas. Resize, rearrange, and lay out a report the way you actually reason about the account — not the way a rigid template forces you to.",
    icon: `<rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/>`,
  },
  {
    title: "Compare any period against any other",
    body: "Add “vs. prior” comparisons to any tile and see period-over-period movement inline. Spot what changed without exporting anything or rebuilding the view.",
    icon: `<path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-6"/>`,
  },
  {
    title: "Custom metrics and conditional rules",
    body: "Define the metrics your team actually uses, then set conditional table rules that highlight the rows worth looking at — reds, ambers and greens where they matter.",
    icon: `<path d="M12 20V10M18 20V4M6 20v-4"/>`,
  },
  {
    title: "Annotations that mark what you changed",
    body: "Pin an annotation to a date to record exactly what you changed and when — a budget shift, a new creative, a landing-page test — so the chart tells the whole story later.",
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  },
  {
    title: "Reusable templates",
    body: "Save any layout as a template — personal or app-wide — and spin up a consistent report for a new client or campaign in seconds.",
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
  },
  {
    title: "Blended, currency-unified data underneath",
    body: "Every tile draws from one normalized schema across Meta, TikTok, Snapchat, Google and your store — currency-unified and synced hourly, so the numbers agree.",
    icon: `<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/>`,
  },
];
---

<Layout
  title="Dashboards"
  description="AdFunnl Dashboards — a freeform canvas that matches how you think. Drag KPIs, charts, funnels, geo maps and tables anywhere, compare any period, and save reusable templates."
>

  <!-- Breadcrumb + hero -->
  <section class="relative overflow-hidden bg-white px-6 pt-14 pb-16 sm:pt-16">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_60%_50%_at_50%_-10%,#e6e1fb,transparent)]"></div>
    <div class="mx-auto max-w-6xl">
      <nav class="mb-8 flex items-center gap-2 text-sm text-zinc-400">
        <a href="/" class="hover:text-zinc-700 transition">Home</a>
        <span>/</span>
        <span class="text-zinc-400">Features</span>
        <span>/</span>
        <span class="font-medium text-zinc-700">Dashboards</span>
      </nav>

      <div class="grid items-center gap-12 lg:grid-cols-[1fr_1.05fr]">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-semibold text-brand-700">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/></svg>
            Core feature · Dashboards
          </span>
          <h1 class="mt-5 font-display text-4xl font-bold leading-[1.08] tracking-tight text-zinc-950 sm:text-5xl">
            Reports that match how you think
          </h1>
          <p class="mt-5 text-lg leading-relaxed text-zinc-500">
            A freeform canvas — not a rigid template. Drag KPI tiles, charts, funnels,
            geo maps, tables and creative galleries wherever they make sense. Add
            comparisons, custom metrics and annotations, then save any layout as a
            reusable template.
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href={`${APP_URL}/signup`}
               class="rounded-xl bg-brand-600 px-7 py-3.5 text-center text-base font-semibold text-white shadow-lg shadow-brand-200 transition hover:bg-brand-700">
              Start free
            </a>
            <a href="/#features"
               class="rounded-xl border border-zinc-200 bg-white px-7 py-3.5 text-center text-base font-semibold text-zinc-700 transition hover:bg-zinc-50">
              See all features
            </a>
          </div>
        </div>

        <!-- Canvas preview -->
        <div class="rounded-2xl border border-zinc-200/80 bg-white p-5 shadow-2xl shadow-brand-900/10 ring-1 ring-zinc-900/[0.03]">
          <div class="mb-4 flex items-center justify-between">
            <span class="text-sm font-semibold text-zinc-800">Client · Q3 performance</span>
            <span class="rounded-md bg-brand-50 px-2 py-1 text-[10px] font-semibold uppercase tracking-wide text-brand-700">Template</span>
          </div>
          <div class="grid grid-cols-6 gap-2.5">
            <div class="col-span-2 rounded-lg border border-zinc-200 bg-zinc-50 p-3"><p class="text-[10px] text-zinc-400">Blended ROAS</p><p class="font-display text-base font-bold text-zinc-900">4.42×</p><p class="text-[10px] font-semibold text-emerald-600">+0.6 vs. prior</p></div>
            <div class="col-span-2 rounded-lg border border-zinc-200 bg-zinc-50 p-3"><p class="text-[10px] text-zinc-400">Revenue</p><p class="font-display text-base font-bold text-zinc-900">$213k</p><p class="text-[10px] font-semibold text-emerald-600">+18% vs. prior</p></div>
            <div class="col-span-2 rounded-lg border border-zinc-200 bg-zinc-50 p-3"><p class="text-[10px] text-zinc-400">CAC</p><p class="font-display text-base font-bold text-zinc-900">$21</p><p class="text-[10px] font-semibold text-emerald-600">-9% vs. prior</p></div>
            <div class="col-span-4 rounded-lg border border-zinc-200 bg-zinc-50 p-3">
              <p class="mb-2 text-[10px] text-zinc-400">Spend vs. revenue</p>
              <div class="flex h-20 items-end gap-1.5">
                {[40, 55, 48, 66, 60, 78, 72, 90].map((h) => (
                  <div class="flex flex-1 flex-col items-center justify-end gap-1">
                    <div class="w-full rounded-t bg-brand-600" style={`height:${h}%`}></div>
                    <div class="w-full rounded-t bg-brand-200" style={`height:${Math.round(h * 0.4)}%`}></div>
                  </div>
                ))}
              </div>
            </div>
            <div class="col-span-2 rounded-lg border border-zinc-200 bg-zinc-50 p-3">
              <p class="mb-2 text-[10px] text-zinc-400">Funnel</p>
              <div class="space-y-1.5">
                <div class="h-2.5 w-full rounded bg-brand-600"></div>
                <div class="h-2.5 w-4/5 rounded bg-brand-400"></div>
                <div class="h-2.5 w-3/5 rounded bg-brand-300"></div>
                <div class="h-2.5 w-2/5 rounded bg-brand-200"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tile types strip -->
  <section class="border-y border-zinc-100 bg-zinc-50/60 px-6 py-14">
    <div class="mx-auto max-w-6xl">
      <p class="mb-8 text-center text-sm font-semibold uppercase tracking-widest text-zinc-400">
        Every tile type on one canvas
      </p>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
        {tileTypes.map((t) => (
          <div class="rounded-xl border border-zinc-100 bg-white p-4 text-center">
            <p class="text-sm font-semibold text-zinc-900">{t.name}</p>
            <p class="mt-1 text-xs leading-snug text-zinc-500">{t.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="bg-white px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-display text-3xl font-bold tracking-tight text-zinc-950 sm:text-4xl">
          Built for the way you actually report
        </h2>
        <p class="mt-4 text-lg text-zinc-500">
          A canvas flexible enough for your own logic, on top of data that finally agrees with itself.
        </p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {capabilities.map((c) => (
          <div class="rounded-2xl border border-zinc-100 bg-zinc-50/60 p-7 transition hover:border-brand-200 hover:bg-brand-50/40">
            <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-brand-600 text-white">
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
            </div>
            <h3 class="font-display text-lg font-bold text-zinc-950">{c.title}</h3>
            <p class="mt-2.5 text-sm leading-relaxed text-zinc-500">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 pb-24">
    <div class="mx-auto max-w-5xl rounded-3xl bg-ink px-6 py-16 text-center sm:py-20">
      <div class="mx-auto max-w-2xl">
        <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Build your first dashboard in minutes
        </h2>
        <p class="mt-4 text-lg text-zinc-400">
          Connect an account, drop in a few tiles, and save it as a template your whole team can reuse.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={`${APP_URL}/signup`}
             class="w-full rounded-xl bg-brand-600 px-8 py-3.5 text-base font-semibold text-white transition hover:bg-brand-500 sm:w-auto">
            Start free
          </a>
          <a href={`${APP_URL}/demo`}
             class="w-full rounded-xl border border-white/20 px-8 py-3.5 text-base font-semibold text-white transition hover:bg-white/10 sm:w-auto">
            Book a demo
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
