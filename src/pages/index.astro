  <style is:global>
    /* Scroll-reveal (only hidden when JS is present to reveal it) */
    .js .reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s ease, transform .7s cubic-bezier(.2,.7,.2,1); }
    .js .reveal.in { opacity: 1; transform: none; }

    /* Hero entrance — CSS-only so above-the-fold content never depends on JS */
    @keyframes heroIn { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
    .hero-app { animation: heroIn .8s cubic-bezier(.2,.7,.2,1) both; }

    /* Hero source chips cascade in */
    @keyframes chipIn { to { opacity: 1; transform: none; } }
    .chip-in { opacity: 0; transform: translateY(8px); animation: chipIn .5s ease forwards; animation-delay: var(--d, 0ms); }

    /* Hero chart bars grow from the baseline */
    @keyframes barGrow { from { transform: scaleY(0); } to { transform: scaleY(1); } }
    .bar { transform-origin: bottom; animation: barGrow .8s cubic-bezier(.2,.7,.2,1) both; animation-delay: var(--d, 0ms); }

    /* Ambient live indicators */
    @keyframes livePulse { 0%,100% { opacity: 1; } 50% { opacity: .35; } }
    .live-dot { animation: livePulse 1.6s ease-in-out infinite; }
    @keyframes caretBlink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }
    .stream-caret { animation: caretBlink 1s step-end infinite; }

    /* Hook & Hold curve draws itself once revealed */
    .hh-line { stroke-dasharray: 1; stroke-dashoffset: 1; }
    .reveal.in .hh-line { transition: stroke-dashoffset 1.6s ease .2s; stroke-dashoffset: 0; }
    .hh-area { opacity: 0; }
    .reveal.in .hh-area { transition: opacity .8s ease 1s; opacity: 1; }

    /* Verdict flip on the featured Pulse row */
    .verdict { transition: background-color .35s ease, color .35s ease, border-color .35s ease; }
    [data-pulse-row="cycle"] [data-roas] { transition: color .35s ease; }

    @media (prefers-reduced-motion: reduce) {
      .reveal, .hero-app, .chip-in, .bar, .live-dot, .stream-caret, .hh-line, .hh-area, .verdict { animation: none !important; transition: none !important; }
      .js .reveal { opacity: 1 !important; transform: none !important; }
      .chip-in { opacity: 1; }
      .hh-line { stroke-dashoffset: 0; }
      .hh-area { opacity: 1; }
    }
  </style>

  <script>
    document.documentElement.classList.add("js");
    const rm = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // ── Scroll reveal ──────────────────────────────────────────────
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
      }
    }, { threshold: 0.2 });
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

    // ── Hero KPI count-up ──────────────────────────────────────────
    function countUp(el) {
      const raw = el.dataset.value || el.textContent || "";
      const m = raw.match(/^([^0-9.-]*)([0-9]+(?:\.[0-9]+)?)(.*)$/);
      if (!m) return;
      const [, prefix, numStr, suffix] = m;
      const target = parseFloat(numStr);
      const decimals = numStr.includes(".") ? numStr.split(".")[1].length : 0;
      if (rm) { el.textContent = raw; return; }
      const dur = 1200; const start = performance.now();
      function tick(now) {
        const p = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = prefix + (target * eased).toFixed(decimals) + suffix;
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = raw;
      }
      requestAnimationFrame(tick);
    }
    document.querySelectorAll(".count").forEach((el) => countUp(el));

    // ── Pulse verdict badges + featured-row flip ───────────────────
    const VERDICT = {
      scale: { label: "Scale", cls: "bg-emerald-50 text-emerald-700 border-emerald-200" },
      hold:  { label: "Hold",  cls: "bg-amber-50 text-amber-700 border-amber-200" },
      cut:   { label: "Cut",   cls: "bg-rose-50 text-rose-700 border-rose-200" },
    };
    const BASE = "verdict inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium";
    function paint(el, v) { const s = VERDICT[v]; el.className = BASE + " " + s.cls; el.textContent = s.label; }
    document.querySelectorAll(".verdict").forEach((el) => paint(el, el.dataset.verdict));

    const cycleRow = document.querySelector('[data-pulse-row="cycle"]');
    if (cycleRow && !rm) {
      const seq = [
        { roas: "5.2×", v: "scale" },
        { roas: "3.6×", v: "scale" },
        { roas: "2.7×", v: "hold" },
        { roas: "4.1×", v: "scale" },
      ];
      const badge = cycleRow.querySelector(".verdict");
      const roasCell = cycleRow.querySelector("[data-roas]");
      let i = 0;
      setInterval(() => {
        i = (i + 1) % seq.length;
        roasCell.textContent = seq[i].roas;
        roasCell.style.color = seq[i].v === "hold" ? "#b45309" : "#0f766e";
        paint(badge, seq[i].v);
      }, 2200);
    }

    // ── Chat streaming (loops) ─────────────────────────────────────
    const streamEl = document.getElementById("chat-stream");
    const ANSWER = "TikTok took 62% of spend but returned only 38% of revenue. Two Meta retargeting sets carried blended ROAS this month — shifting ~$4.2k out of TikTok prospecting into them is the clearest win.";
    if (streamEl) {
      if (rm) { streamEl.textContent = ANSWER; }
      else {
        let i = 0;
        function type() {
          streamEl.textContent = ANSWER.slice(0, i);
          i++;
          if (i <= ANSWER.length) setTimeout(type, 22);
          else setTimeout(() => { i = 0; setTimeout(type, 400); }, 3800);
        }
        type();
      }
    }
  </script>

