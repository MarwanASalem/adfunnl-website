---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.adfunnl.com";

// Data sources — shown as connected chips (no emoji, no fake logos: a
// colored source dot + the platform name reads as "connected account").
const adPlatforms = [
  { name: "Meta",     color: "#1877F2" },
  { name: "TikTok",   color: "#111111" },
  { name: "Snapchat", color: "#FFC300" },
  { name: "Google",   color: "#EA4335" },
];
const stores = [
  { name: "Shopify",      color: "#95BF47" },
  { name: "Salla",        color: "#00C48C" },
  { name: "Bosta",        color: "#E30613" },
  { name: "Easy Orders",  color: "#5738C9" },
  { name: "Google Sheets", color: "#0F9D58" },
];

// Signature hero preview: three blended KPI tiles + a mini spend/revenue chart.
const kpis = [
  { label: "Ad spend",   value: "$48.2k", delta: "-6%",  down: false },
  { label: "Revenue",    value: "$213k",  delta: "+18%", down: true  },
  { label: "Blended ROAS", value: "4.42×", delta: "+0.6", down: true },
];
const bars = [38, 52, 41, 63, 58, 74, 69, 88];

// ── Live snapshots section (faithful recreations of real app screens) ──
// Pulse: real verdicts are Scale (emerald) / Hold (amber) / Cut (rose).
const pulseRows = [
  { name: "Retargeting · Broad", spend: "$3,240", revenue: "$16,900", roas: "5.2×", ctr: "2.4%", verdict: "scale" },
  { name: "Prospecting · Lookalike 3%", spend: "$5,110", revenue: "$14,300", roas: "2.8×", ctr: "1.9%", verdict: "hold" },
  { name: "Cold · Interest stack", spend: "$2,780", revenue: "$3,900", roas: "1.4×", ctr: "1.1%", verdict: "cut" },
];

// Hook & Hold: hook = 3-sec plays ÷ impressions, hold = thruplays ÷ impressions.
// Retention curve as % of viewers still watching across the video.
const retention = [100, 92, 78, 63, 54, 48, 44, 41, 39, 37, 35];
const W = 300, H = 120, PAD = 6;
const rPts = retention.map((v, i) => {
  const x = (i / (retention.length - 1)) * (W - PAD * 2) + PAD;
  const y = (1 - v / 100) * (H - PAD * 2) + PAD;
  return [Math.round(x * 10) / 10, Math.round(y * 10) / 10];
});
const rLine = rPts.map((p, i) => `${i ? "L" : "M"}${p[0]} ${p[1]}`).join(" ");
const rArea = `${rLine} L${rPts[rPts.length - 1][0]} ${H - PAD} L${rPts[0][0]} ${H - PAD} Z`;

// ── Hero signature: the Blended Overview (e-commerce) dashboard ──
// Faithful to the real template — per-platform metric cards + a blended row.
// Numbers are anonymized demo data (no real client/account).
const ovCols = [
  { label: "Spend",     cur: true },
  { label: "Purchases", cur: false, hideSm: true },
  { label: "Cost/Conv.",cur: true,  hideSm: true },
  { label: "ROAS",      cur: false },
  { label: "Revenue",   cur: true },
];
// cell = [value, deltaPct, up?, good?]
const ovRows = [
  { name: "Meta",     color: "#1877F2", cells: [["18,824","17.6",false,true],["223","20.5",true,true],["84.41","31.6",false,true],["5.79×","42.8",true,true],["108,976","17.6",true,true]] },
  { name: "TikTok",   color: "#111111", cells: [["3,767","19.5",false,true],["43","23.2",false,false],["87.60","4.8",true,false],["5.75×","2.6",false,false],["21,653","21.6",false,false]] },
  { name: "Google",   color: "#EA4335", cells: [["417","13.9",false,true],["20","60.1",false,false],["21.18","55.6",true,false],["24.5×","51.6",true,true],["10,256","58.3",true,true]] },
  { name: "Snapchat", color: "#FFC300", cells: [["7,081","1.9",true,false],["120","10.1",true,true],["59.01","7.5",false,true],["8.60×","8.1",true,true],["60,906","8.7",true,true]] },
];
const ovBlended = [
  { label: "Total spend",  v: "26,323", cur: true },
  { label: "Conversions",  v: "363",    cur: false, hideSm: true },
  { label: "Blended CPP",  v: "74",     cur: true,  hideSm: true },
  { label: "Blended ROAS", v: "6.69×",  cur: false },
  { label: "Revenue",      v: "180,138",cur: true },
];
---

<Layout title="Every ad platform. Every store. One source of truth.">

  <!-- ============================== HERO ============================== -->
  <section class="relative overflow-hidden bg-white px-6 pt-16 pb-20 sm:pt-20">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_70%_55%_at_50%_-15%,#e6e1fb,transparent)]"></div>

    <div class="mx-auto grid max-w-6xl items-center gap-14 lg:grid-cols-[1.05fr_1fr]">
      <!-- Copy -->
      <div class="text-center lg:text-left">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-xs font-semibold text-brand-700">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-500 opacity-70"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-600"></span>
          </span>
          Synced hourly · English &amp; Arabic
        </div>

        <h1 class="font-display text-[2.6rem] font-bold leading-[1.05] tracking-tight text-zinc-950 sm:text-6xl">
          Every ad platform.<br />
          Every store.<br />
          <span class="text-brand-600">One source of truth.</span>
        </h1>

        <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-zinc-500 lg:mx-0">
          AdFunnl pulls Meta, TikTok, Snapchat and Google — plus your Shopify and
          Salla revenue — into a single, always-fresh workspace. Build the reports
          you actually think in, and ask your data questions in plain English.
        </p>

        <div class="mt-9 flex flex-col items-center gap-4 sm:flex-row lg:justify-start justify-center">
          <a href={`${APP_URL}/signup`}
             class="w-full rounded-xl bg-brand-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-200 transition hover:bg-brand-700 sm:w-auto">
            Start free
          </a>
          <a href={`${APP_URL}/demo`}
             class="w-full rounded-xl border border-zinc-200 bg-white px-8 py-3.5 text-base font-semibold text-zinc-700 transition hover:bg-zinc-50 sm:w-auto">
            Book a demo
          </a>
        </div>

        <p class="mt-6 text-sm text-zinc-400">
          Trusted by brands and agencies running paid across four platforms and two languages.
        </p>
      </div>

      <!-- Signature: the real Blended Overview (e-commerce) dashboard, in an
           app window. Anonymized demo data, reveals + count-up on load. -->
      <div class="hero-app relative mx-auto w-full max-w-md lg:max-w-none">
        <div class="relative overflow-hidden rounded-2xl border border-zinc-200/80 bg-white shadow-2xl shadow-brand-900/20 ring-1 ring-zinc-900/[0.04]">
          <!-- app top bar -->
          <div class="flex items-center gap-2 border-b border-zinc-100 bg-white px-3.5 py-2.5">
            <span class="flex h-5 w-5 items-center justify-center rounded-md bg-brand-600 text-[10px] font-bold text-white">A</span>
            <div class="flex items-center gap-1.5 text-[11px] font-semibold text-zinc-700">
              <span class="flex h-4 w-4 items-center justify-center rounded bg-brand-100 text-[8px] font-bold text-brand-700">DS</span>
              Demo store
            </div>
            <span class="ms-1 hidden rounded-md border border-zinc-200 px-2 py-0.5 text-[10px] font-medium text-zinc-500 sm:inline-block">This month</span>
            <span class="hidden rounded-md border border-brand-200 bg-brand-50 px-2 py-0.5 text-[10px] font-medium text-brand-700 sm:inline-block">vs. last period</span>
            <div class="ms-auto flex items-center gap-1.5">
              <span class="hidden rounded-md border border-zinc-200 px-2 py-0.5 text-[10px] font-medium text-zinc-500 sm:inline-block">Share</span>
              <span class="rounded-md bg-brand-600 px-2 py-0.5 text-[10px] font-semibold text-white">+ Widget</span>
            </div>
          </div>

          <!-- dashboard body -->
          <div class="space-y-2.5 bg-zinc-50/50 p-3.5">
            <!-- Overview banner -->
            <div class="flex items-center justify-between rounded-lg bg-brand-600 px-3.5 py-2 shadow-sm shadow-brand-900/20">
              <span class="font-display text-sm font-bold tracking-tight text-white">Overview</span>
              <span class="inline-flex items-center gap-1.5 rounded-md bg-white/15 px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-white">
                <span class="live-dot h-1.5 w-1.5 rounded-full bg-emerald-300"></span>Live
              </span>
            </div>

            <!-- per-platform metric rows -->
            {ovRows.map((row) => (
              <div class="flex items-stretch gap-2">
                <div class="flex w-7 shrink-0 items-center justify-center">
                  <span class="flex h-7 w-7 items-center justify-center rounded-lg text-[10px] font-bold text-white shadow-sm" style={`background:${row.color}`}>{row.name[0]}</span>
                </div>
                <div class="grid flex-1 grid-cols-3 gap-1.5 sm:grid-cols-5">
                  {row.cells.map((c, i) => (
                    <div class={`rounded-lg border border-zinc-100 bg-white px-2 py-1.5 ${ovCols[i].hideSm ? "hidden sm:block" : ""}`}>
                      <p class="truncate text-[8px] font-medium uppercase tracking-wide text-zinc-400">{ovCols[i].label}</p>
                      <p class="mt-0.5 truncate font-display text-[12px] font-bold leading-tight text-zinc-900">
                        {ovCols[i].cur && <span class="text-[8px] font-semibold text-zinc-400">SAR </span>}{c[0]}
                      </p>
                      <p class={`mt-0.5 flex items-center gap-0.5 text-[8px] font-semibold ${c[3] ? "text-emerald-600" : "text-rose-500"}`}>
                        <span>{c[2] ? "▲" : "▼"}</span>{c[1]}%
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            ))}

            <div class="border-t border-dashed border-zinc-200"></div>

            <!-- blended row (highlighted) -->
            <div class="flex items-stretch gap-2">
              <div class="flex w-7 shrink-0 items-center justify-center">
                <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-brand-600 text-white shadow-sm">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h18l-7 8v6l-4 2v-8z"/></svg>
                </span>
              </div>
              <div class="grid flex-1 grid-cols-3 gap-1.5 sm:grid-cols-5">
                {ovBlended.map((b, i) => (
                  <div class={`rounded-lg border border-brand-100 bg-brand-50/60 px-2 py-1.5 ${b.hideSm ? "hidden sm:block" : ""}`}>
                    <p class="truncate text-[8px] font-medium uppercase tracking-wide text-brand-400">{b.label}</p>
                    <p class="mt-0.5 truncate font-display text-[13px] font-bold leading-tight text-brand-900">
                      {b.cur && <span class="text-[8px] font-semibold text-brand-400">SAR </span>}
                      {i === 3 ? <span class="count" data-value={b.v}>{b.v}</span> : b.v}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- floating assistant bubble -->
        <div class="absolute -bottom-4 -left-3 hidden max-w-[15rem] rounded-xl border border-zinc-200 bg-white p-3 shadow-xl lg:block">
          <div class="flex items-start gap-2">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-600 text-[11px] font-bold text-white">AI</span>
            <p class="text-[11px] leading-snug text-zinc-600">"Which campaigns wasted budget last week?"</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= SOCIAL PROOF ========================= -->
  <section class="border-y border-zinc-100 bg-zinc-50/70">
    <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-center gap-x-10 gap-y-3 px-6 py-5 text-sm font-medium text-zinc-500">
      <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>Connect in minutes</span>
      <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>Synced hourly</span>
      <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>English &amp; Arabic (RTL)</span>
      <span class="flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>Agency-ready multi-client</span>
    </div>
  </section>

  <!-- ============================ UNIFY ============================ -->
  <section id="integrations" class="bg-white px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-14 lg:grid-cols-2 lg:items-center">
        <div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-600">Unify</p>
          <h2 class="font-display text-3xl font-bold tracking-tight text-zinc-950 sm:text-4xl">
            Stop stitching together spreadsheets
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-zinc-500">
            Four ad managers, three currencies, and a store dashboard that never
            agrees with any of them. AdFunnl ends the reconciliation tax. We ingest
            every platform into one normalized schema, unify currencies automatically,
            and blend it into true cross-channel numbers — so "how are we actually
            doing?" has one answer, not five tabs.
          </p>
          <ul class="mt-7 space-y-3 text-sm text-zinc-600">
            {[
              "Hourly automated syncs, currency-unified, blended metrics",
              "One normalized schema across every source",
              "True cross-channel numbers you can stand behind",
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- source columns -->
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-zinc-100 bg-zinc-50/70 p-5">
            <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-zinc-400">Ad platforms</p>
            <ul class="space-y-3">
              {adPlatforms.map((p) => (
                <li class="flex items-center gap-3 text-sm font-medium text-zinc-700">
                  <span class="h-2.5 w-2.5 rounded-full" style={`background:${p.color}`}></span>{p.name} Ads
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-2xl border border-zinc-100 bg-zinc-50/70 p-5">
            <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-zinc-400">Stores &amp; data</p>
            <ul class="space-y-3">
              {stores.map((p) => (
                <li class="flex items-center gap-3 text-sm font-medium text-zinc-700">
                  <span class="h-2.5 w-2.5 rounded-full" style={`background:${p.color}`}></span>{p.name}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================= SEE IT LIVE ========================= -->
  <section id="live" class="relative overflow-hidden bg-ink px-6 py-24">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(87,56,201,0.35),transparent)]"></div>
    <div class="mx-auto max-w-6xl">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-brand-300">The product, moving</p>
        <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Not screenshots. The actual screens.
        </h2>
        <p class="mt-4 text-lg text-zinc-400">
          These are faithful recreations of AdFunnl's real workspace — verdicts flipping,
          answers streaming, retention curves drawing themselves. This is what your Monday looks like.
        </p>
      </div>

      <!-- Pulse — featured, wide -->
      <div class="reveal mt-14 overflow-hidden rounded-2xl border border-white/10 bg-white shadow-2xl shadow-black/40">
        <div class="flex items-center gap-2 border-b border-zinc-100 bg-zinc-50 px-4 py-2.5">
          <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
          <div class="ms-2 flex items-center gap-1.5 text-[11px] font-medium text-zinc-400">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>Pulse · Meta · Acme Cosmetics
          </div>
          <span class="ms-auto rounded-md bg-brand-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-brand-700">Scaling verdicts</span>
        </div>
        <div class="p-5 sm:p-6">
          <div class="mb-3 flex items-center justify-between">
            <p class="text-sm font-semibold text-zinc-800">Active campaigns</p>
            <p class="text-xs text-zinc-400">Rule: ROAS ≥ 3.0 to scale</p>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full min-w-[540px] text-left text-sm">
              <thead>
                <tr class="border-b border-zinc-100 text-[11px] font-semibold uppercase tracking-wide text-zinc-400">
                  <th class="py-2 pe-3 font-semibold">Campaign</th>
                  <th class="py-2 px-3 text-right font-semibold">Spend</th>
                  <th class="py-2 px-3 text-right font-semibold">Revenue</th>
                  <th class="py-2 px-3 text-right font-semibold">ROAS</th>
                  <th class="py-2 px-3 text-right font-semibold">CTR</th>
                  <th class="py-2 ps-3 text-right font-semibold">Verdict</th>
                </tr>
              </thead>
              <tbody>
                {pulseRows.map((r, i) => (
                  <tr class="border-b border-zinc-50 last:border-0" data-pulse-row={i === 0 ? "cycle" : undefined}>
                    <td class="py-3 pe-3 font-medium text-zinc-700">{r.name}</td>
                    <td class="py-3 px-3 text-right tabular-nums text-zinc-600">{r.spend}</td>
                    <td class="py-3 px-3 text-right tabular-nums text-zinc-600">{r.revenue}</td>
                    <td class="py-3 px-3 text-right font-semibold tabular-nums text-zinc-900" data-roas>{r.roas}</td>
                    <td class="py-3 px-3 text-right tabular-nums text-zinc-600">{r.ctr}</td>
                    <td class="py-3 ps-3 text-right">
                      <span class="verdict inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium" data-verdict={r.verdict}></span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Two-up: Assistant (streaming) + Hook & Hold (drawing curve) -->
      <div class="mt-6 grid gap-6 lg:grid-cols-2">
        <!-- Chat with your data -->
        <div class="reveal overflow-hidden rounded-2xl border border-white/10 bg-white shadow-2xl shadow-black/40">
          <div class="flex items-center gap-2 border-b border-zinc-100 bg-zinc-50 px-4 py-2.5">
            <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
            <div class="ms-2 flex items-center gap-1.5 text-[11px] font-medium text-zinc-400">
              <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>Chat with your data
            </div>
          </div>
          <div class="space-y-3 p-5">
            <div class="flex justify-end">
              <p class="max-w-[85%] rounded-2xl rounded-br-sm bg-brand-600 px-3.5 py-2 text-sm text-white">
                Recap TikTok vs Meta this month — where did we waste budget?
              </p>
            </div>
            <div class="flex gap-2.5">
              <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-600 text-[11px] font-bold text-white">AI</span>
              <div class="min-w-0 flex-1">
                <p class="rounded-2xl rounded-bl-sm bg-zinc-100 px-3.5 py-2.5 text-sm leading-relaxed text-zinc-700">
                  <span id="chat-stream"></span><span class="stream-caret text-brand-600">▍</span>
                </p>
                <div class="mt-2.5 rounded-lg border border-zinc-200 bg-zinc-50/70 text-xs">
                  <div class="flex items-center gap-1.5 px-2.5 py-1.5 font-medium text-zinc-500">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h10"/></svg>
                    Data used
                  </div>
                  <div class="space-y-1 border-t border-zinc-100 px-2.5 py-2 font-mono text-[10px] leading-relaxed text-zinc-500">
                    <p><span class="text-zinc-400">META_INSIGHTS</span> · 30d · spend, roas by campaign</p>
                    <p><span class="text-zinc-400">TIKTOK_INSIGHTS</span> · 30d · spend, roas by campaign</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Hook & Hold -->
        <div class="reveal overflow-hidden rounded-2xl border border-white/10 bg-white shadow-2xl shadow-black/40">
          <div class="flex items-center gap-2 border-b border-zinc-100 bg-zinc-50 px-4 py-2.5">
            <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-zinc-300"></span>
            <div class="ms-2 flex items-center gap-1.5 text-[11px] font-medium text-zinc-400">
              <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>Creatives · Hook &amp; Hold
            </div>
          </div>
          <div class="p-5">
            <div class="mb-4 flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-zinc-800">Where viewers drop off</p>
                <p class="mt-0.5 text-xs text-zinc-400">Spend-weighted · Meta video</p>
              </div>
              <div class="flex gap-4 text-right">
                <div>
                  <p class="text-[10px] font-medium uppercase tracking-wide text-zinc-400">Hook</p>
                  <p class="font-display text-lg font-bold text-brand-600">31%</p>
                </div>
                <div>
                  <p class="text-[10px] font-medium uppercase tracking-wide text-zinc-400">Hold</p>
                  <p class="font-display text-lg font-bold text-brand-600">9.4%</p>
                </div>
              </div>
            </div>
