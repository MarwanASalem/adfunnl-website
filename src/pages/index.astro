            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/></svg>
            View-only, no login
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================ CTA ============================ -->
  <section class="px-6 pb-24">
    <div class="mx-auto max-w-5xl overflow-hidden rounded-3xl bg-ink px-6 py-16 text-center sm:py-20">
      <div class="mx-auto max-w-2xl">
        <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          See all your ad spend clearly — in one place, shared with your clients.
        </h2>
        <p class="mt-4 text-lg text-zinc-400">
          Connect your first account in minutes. No spreadsheet surgery required.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={`${APP_URL}/signup`}
             class="w-full rounded-xl bg-brand-600 px-8 py-3.5 text-base font-semibold text-white transition hover:bg-brand-500 sm:w-auto">
            Start free
          </a>
          <a href={`${APP_URL}/demo`}
             class="w-full rounded-xl border border-white/20 px-8 py-3.5 text-base font-semibold text-white transition hover:bg-white/10 sm:w-auto">
            Book a demo
          </a>
        </div>
      </div>
    </div>
  </section>

  <style is:global>
    /* Scroll-reveal (only hidden when JS is present to reveal it) */
    .js .reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s ease, transform .7s cubic-bezier(.2,.7,.2,1); }
    .js .reveal.in { opacity: 1; transform: none; }

    /* Hero entrance — CSS-only so above-the-fold content never depends on JS */
    @keyframes heroIn { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
    .hero-app { animation: heroIn .8s cubic-bezier(.2,.7,.2,1) both; }

    /* Hero source chips cascade in */
    @keyframes chipIn { to { opacity: 1; transform: none; } }
    .chip-in { opacity: 0; transform: translateY(8px); animation: chipIn .5s ease forwards; animation-delay: var(--d, 0ms); }

    /* Hero chart bars grow from the baseline */
    @keyframes barGrow { from { transform: scaleY(0); } to { transform: scaleY(1); } }
    .bar { transform-origin: bottom; animation: barGrow .8s cubic-bezier(.2,.7,.2,1) both; animation-delay: var(--d, 0ms); }

    /* Ambient live indicators */
    @keyframes livePulse { 0%,100% { opacity: 1; } 50% { opacity: .35; } }
    .live-dot { animation: livePulse 1.6s ease-in-out infinite; }
    @keyframes caretBlink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }
    .stream-caret { animation: caretBlink 1s step-end infinite; }

    /* Hook & Hold curve draws itself once revealed */
    .hh-line { stroke-dasharray: 1; stroke-dashoffset: 1; }
    .reveal.in .hh-line { transition: stroke-dashoffset 1.6s ease .2s; stroke-dashoffset: 0; }
    .hh-area { opacity: 0; }
    .reveal.in .hh-area { transition: opacity .8s ease 1s; opacity: 1; }

    /* Verdict flip on the featured Pulse row */
    .verdict { transition: background-color .35s ease, color .35s ease, border-color .35s ease; }
    [data-pulse-row="cycle"] [data-roas] { transition: color .35s ease; }

    /* ── Animated data-flow diagram ── */
    .flow-stream { fill: none; stroke: #e0d9f9; stroke-width: 2; stroke-dasharray: 5 9; stroke-linecap: round; animation: flowDash 1.1s linear infinite; }
    @keyframes flowDash { to { stroke-dashoffset: -14; } }
    .flow-hub-ring { transform-box: fill-box; transform-origin: center; animation: flowHub 2.6s ease-in-out infinite; }
    @keyframes flowHub { 0%,100% { opacity: .55; transform: scale(1); } 50% { opacity: 1; transform: scale(1.08); } }
    .flow-bar { transform-box: fill-box; transform-origin: bottom; animation: flowBar 2.4s cubic-bezier(.4,0,.2,1) infinite; animation-delay: var(--d, 0s); }
    @keyframes flowBar { 0%,100% { transform: scaleY(calc(var(--h) * .55)); } 50% { transform: scaleY(var(--h)); } }
    .flow-check { animation: flowCheck 2.8s ease-in-out infinite; }
    @keyframes flowCheck { 0%,70%,100% { opacity: 1; } 80% { opacity: .3; } }

    /* ── Drag & drop builder ── */
    .dnd-tile { animation: dndDrag 4.8s cubic-bezier(.4,0,.2,1) infinite; }
    @keyframes dndDrag {
      0%   { left: 60%; top: -6%; opacity: 0; }
      10%  { left: 58%; top: 2%;  opacity: 1; }
      55%  { left: 53%; top: 0%;  opacity: 1; }
      70%  { left: 53%; top: 0%;  opacity: 1; }
      82%  { left: 53%; top: 0%;  opacity: 1; }
      90%,100% { left: 53%; top: 0%; opacity: 0; }
    }
    .dnd-drop { border-color: #ddd6fe; background: rgba(139,111,240,.05); animation: dndDropPulse 4.8s ease-in-out infinite; }
    @keyframes dndDropPulse {
      0%,45%   { border-color: #ddd6fe; background: rgba(139,111,240,.05); }
      55%,82%  { border-color: #8b6ff0; background: rgba(139,111,240,.14); }
      90%,100% { border-color: #ddd6fe; background: rgba(139,111,240,.05); }
    }
    .dnd-cursor { animation: dndClick 4.8s ease-in-out infinite; }
    @keyframes dndClick { 0%,52%,72%,100% { transform: scale(1); } 60% { transform: scale(.82); } }

    /* ── Month-over-month chart (reveal-triggered) ── */
    .mom-bar { transform-box: fill-box; transform-origin: bottom; transform: scaleY(0); }
    .reveal.in .mom-bar { transition: transform .9s cubic-bezier(.2,.7,.2,1); transform: scaleY(1); }
    .mom-line { stroke-dasharray: 1; stroke-dashoffset: 1; }
    .reveal.in .mom-line { transition: stroke-dashoffset 1.4s ease .5s; stroke-dashoffset: 0; }
    .mom-dot { opacity: 0; }
    .reveal.in .mom-dot { transition: opacity .3s ease; opacity: 1; }

    /* ── Currency unification (reveal-triggered) ── */
    .cur-chip { opacity: 0; transform: translateX(-10px); }
    .reveal.in .cur-chip { transition: opacity .5s ease, transform .5s cubic-bezier(.2,.7,.2,1); opacity: 1; transform: none; }
    .reveal.in .cur-arrow { animation: curArrow 1.6s ease-in-out .6s infinite; }
    @keyframes curArrow { 0%,100% { transform: translateY(-2px); opacity: .6; } 50% { transform: translateY(2px); opacity: 1; } }

    /* ── Team invite avatars (reveal-triggered) ── */
    .team-avatar { opacity: 0; transform: scale(.6); }
    .reveal.in .team-avatar { transition: opacity .4s ease, transform .4s cubic-bezier(.34,1.56,.64,1); opacity: 1; transform: none; }

    @media (prefers-reduced-motion: reduce) {
      .reveal, .hero-app, .chip-in, .bar, .live-dot, .stream-caret, .hh-line, .hh-area, .verdict,
      .flow-stream, .flow-hub-ring, .flow-bar, .flow-check,
      .dnd-tile, .dnd-drop, .dnd-cursor, .cur-arrow { animation: none !important; transition: none !important; }
      .dnd-tile { left: 53% !important; top: 0 !important; opacity: 1 !important; }
      .mom-bar { transform: scaleY(1) !important; }
      .mom-line { stroke-dashoffset: 0 !important; }
      .mom-dot, .cur-chip, .team-avatar { opacity: 1 !important; transform: none !important; }
      .js .reveal { opacity: 1 !important; transform: none !important; }
      .chip-in { opacity: 1; }
      .hh-line { stroke-dashoffset: 0; }
      .hh-area { opacity: 1; }
    }
  </style>

  <script>
    document.documentElement.classList.add("js");
    const rm = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    // Reduced motion: freeze the SVG data-flow particles (SMIL isn't paused by CSS).
    if (rm) {
      const flowSvg = document.getElementById("flow-svg");
      if (flowSvg && typeof flowSvg.pauseAnimations === "function") flowSvg.pauseAnimations();
    }

    // ── Scroll reveal ──────────────────────────────────────────────
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
      }
    }, { threshold: 0.2 });
    document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

    // ── Currency total count-up (comma-formatted), fires on scroll ──
    const curTotal = document.querySelector(".cur-total");
    if (curTotal) {
      const target = parseInt(curTotal.textContent.replace(/,/g, ""), 10);
      const fmt = (n) => Math.round(n).toLocaleString("en-US");
      if (rm || !Number.isFinite(target)) {
        /* leave static */
      } else {
        const cio = new IntersectionObserver((entries, obs) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            obs.disconnect();
            const dur = 1400, start = performance.now();
            const step = (now) => {
              const p = Math.min(1, (now - start) / dur);
              curTotal.textContent = fmt(target * (1 - Math.pow(1 - p, 3)));
              if (p < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          }
        }, { threshold: 0.5 });
        cio.observe(curTotal);
      }
    }

    // ── Hero KPI count-up ──────────────────────────────────────────
    function countUp(el) {
      const raw = el.dataset.value || el.textContent || "";
      const m = raw.match(/^([^0-9.-]*)([0-9]+(?:\.[0-9]+)?)(.*)$/);
      if (!m) return;
      const [, prefix, numStr, suffix] = m;
      const target = parseFloat(numStr);
      const decimals = numStr.includes(".") ? numStr.split(".")[1].length : 0;
      if (rm) { el.textContent = raw; return; }
      const dur = 1200; const start = performance.now();
      function tick(now) {
        const p = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = prefix + (target * eased).toFixed(decimals) + suffix;
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = raw;
      }
      requestAnimationFrame(tick);
    }
    document.querySelectorAll(".count").forEach((el) => countUp(el));

    // ── Pulse verdict badges + featured-row flip ───────────────────
    const VERDICT = {
      scale: { label: "Scale", cls: "bg-emerald-50 text-emerald-700 border-emerald-200" },
      hold:  { label: "Hold",  cls: "bg-amber-50 text-amber-700 border-amber-200" },
      cut:   { label: "Cut",   cls: "bg-rose-50 text-rose-700 border-rose-200" },
    };
    const BASE = "verdict inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium";
    function paint(el, v) { const s = VERDICT[v]; el.className = BASE + " " + s.cls; el.textContent = s.label; }
    document.querySelectorAll(".verdict").forEach((el) => paint(el, el.dataset.verdict));

    const cycleRow = document.querySelector('[data-pulse-row="cycle"]');
    if (cycleRow && !rm) {
      const seq = [
        { roas: "5.2×", v: "scale" },
        { roas: "3.6×", v: "scale" },
        { roas: "2.7×", v: "hold" },
        { roas: "4.1×", v: "scale" },
      ];
      const badge = cycleRow.querySelector(".verdict");
      const roasCell = cycleRow.querySelector("[data-roas]");
      let i = 0;
      setInterval(() => {
        i = (i + 1) % seq.length;
        roasCell.textContent = seq[i].roas;
        roasCell.style.color = seq[i].v === "hold" ? "#b45309" : "#0f766e";
        paint(badge, seq[i].v);
      }, 2200);
    }

    // ── Chat streaming (loops) ─────────────────────────────────────
    const streamEl = document.getElementById("chat-stream");
    const ANSWER = "TikTok took 62% of spend but returned only 38% of revenue. Two Meta retargeting sets carried blended ROAS this month — shifting ~$4.2k out of TikTok prospecting into them is the clearest win.";
    if (streamEl) {
      if (rm) { streamEl.textContent = ANSWER; }
      else {
        let i = 0;
        function type() {
          streamEl.textContent = ANSWER.slice(0, i);
          i++;
          if (i <= ANSWER.length) setTimeout(type, 22);
          else setTimeout(() => { i = 0; setTimeout(type, 400); }, 3800);
        }
        type();
      }
    }
  </script>

</Layout>
