---
import Layout from "../layouts/Layout.astro";
import PlatformIcon from "../components/PlatformIcon.astro";

const APP_URL = "https://app.adfunnl.com";

// Data sources — connected accounts, shown with their real platform logos.
const adPlatforms = [
  { name: "Meta",     key: "meta" },
  { name: "TikTok",   key: "tiktok" },
  { name: "Snapchat", key: "snapchat" },
  { name: "Google",   key: "google_ads" },
];
const stores = [
  { name: "Shopify",       key: "shopify" },
  { name: "Salla",         key: "salla" },
  { name: "Bosta",         key: "bosta" },
  { name: "Easy Orders",   key: "easy_orders" },
  { name: "Google Sheets", key: "google_sheets" },
];

// Signature hero preview: three blended KPI tiles + a mini spend/revenue chart.
const kpis = [
  { label: "Ad spend",   value: "$48.2k", delta: "-6%",  down: false },
  { label: "Revenue",    value: "$213k",  delta: "+18%", down: true  },
  { label: "Blended ROAS", value: "4.42×", delta: "+0.6", down: true },
];
const bars = [38, 52, 41, 63, 58, 74, 69, 88];

// ── Live snapshots section (faithful recreations of real app screens) ──
// Pulse: real verdicts are Scale (emerald) / Hold (amber) / Cut (rose).
const pulseRows = [
  { name: "Retargeting · Broad", spend: "$3,240", revenue: "$16,900", roas: "5.2×", ctr: "2.4%", verdict: "scale" },
  { name: "Prospecting · Lookalike 3%", spend: "$5,110", revenue: "$14,300", roas: "2.8×", ctr: "1.9%", verdict: "hold" },
  { name: "Cold · Interest stack", spend: "$2,780", revenue: "$3,900", roas: "1.4×", ctr: "1.1%", verdict: "cut" },
];

// Hook & Hold: hook = 3-sec plays ÷ impressions, hold = thruplays ÷ impressions.
// Retention curve as % of viewers still watching across the video.
const retention = [100, 92, 78, 63, 54, 48, 44, 41, 39, 37, 35];
const W = 300, H = 120, PAD = 6;
const rPts = retention.map((v, i) => {
  const x = (i / (retention.length - 1)) * (W - PAD * 2) + PAD;
  const y = (1 - v / 100) * (H - PAD * 2) + PAD;
  return [Math.round(x * 10) / 10, Math.round(y * 10) / 10];
});
const rLine = rPts.map((p, i) => `${i ? "L" : "M"}${p[0]} ${p[1]}`).join(" ");
const rArea = `${rLine} L${rPts[rPts.length - 1][0]} ${H - PAD} L${rPts[0][0]} ${H - PAD} Z`;

// ── Hero signature: the Blended Overview (e-commerce) dashboard ──
// Faithful to the real template — per-platform metric cards + a blended row.
// Numbers are anonymized demo data (no real client/account).
const ovCols = [
  { label: "Spend",     cur: true },
  { label: "Purchases", cur: false, hideSm: true },
  { label: "Cost/Conv.",cur: true,  hideSm: true },
  { label: "ROAS",      cur: false },
  { label: "Revenue",   cur: true },
];
// cell = [value, deltaPct, up?, good?]
const ovRows = [
  { name: "Meta",     key: "meta",       color: "#1877F2", cells: [["18,824","17.6",false,true],["223","20.5",true,true],["84.41","31.6",false,true],["5.79×","42.8",true,true],["108,976","17.6",true,true]] },
  { name: "TikTok",   key: "tiktok",     color: "#111111", cells: [["3,767","19.5",false,true],["43","23.2",false,false],["87.60","4.8",true,false],["5.75×","2.6",false,false],["21,653","21.6",false,false]] },
  { name: "Google",   key: "google_ads", color: "#EA4335", cells: [["417","13.9",false,true],["20","60.1",false,false],["21.18","55.6",true,false],["24.5×","51.6",true,true],["10,256","58.3",true,true]] },
  { name: "Snapchat", key: "snapchat",   color: "#FFC300", cells: [["7,081","1.9",true,false],["120","10.1",true,true],["59.01","7.5",false,true],["8.60×","8.1",true,true],["60,906","8.7",true,true]] },
];
const ovBlended = [
  { label: "Total spend",  v: "26,323", cur: true },
  { label: "Conversions",  v: "363",    cur: false, hideSm: true },
  { label: "Blended CPP",  v: "74",     cur: true,  hideSm: true },
  { label: "Blended ROAS", v: "6.69×",  cur: false },
  { label: "Revenue",      v: "180,138",cur: true },
];

// ── SVG-native platform logos for the animated data-flow diagram ──
// (inside an <svg> we can't use <img>, so Google Ads is inlined as the
// 4-colour "G" and the rest reuse the app's official marks.) Each glyph is a
// nested 26×26 svg placed by a translated parent <g>.
const TIKTOK_D = "M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z";
const SHOPIFY_D = "M15.337 23.979l7.216-1.561s-2.604-17.613-2.625-17.73c-.018-.116-.114-.192-.211-.192s-1.929-.136-1.929-.136-1.275-1.274-1.439-1.411c-.045-.037-.075-.057-.121-.074l-.914 21.104h.023zM11.71 11.305s-.81-.424-1.774-.424c-1.447 0-1.504.906-1.504 1.141 0 1.232 3.24 1.715 3.24 4.629 0 2.295-1.44 3.76-3.406 3.76-2.354 0-3.54-1.465-3.54-1.465l.646-2.086s1.245 1.066 2.28 1.066c.675 0 .975-.545.975-.932 0-1.619-2.654-1.694-2.654-4.359-.034-2.237 1.571-4.416 4.827-4.416 1.257 0 1.875.361 1.875.361l-.945 2.715-.02.01zM11.17.83c.136 0 .271.038.405.135-.984.465-2.064 1.639-2.508 3.992-.656.213-1.293.405-1.889.578C7.697 3.75 8.951.84 11.17.84V.83zm1.235 2.949v.135c-.754.232-1.583.484-2.394.736.466-1.777 1.333-2.645 2.085-2.971.193.501.309 1.176.309 2.1zm.539-2.234c.694.074 1.141.867 1.429 1.755-.349.114-.735.231-1.158.366v-.252c0-.752-.096-1.371-.271-1.871v.002zm2.992 1.289c-.02 0-.06.021-.078.021s-.289.075-.714.21c-.423-1.233-1.176-2.37-2.508-2.37h-.115C12.135.209 11.669 0 11.265 0 8.159 0 6.675 3.877 6.21 5.846c-1.194.365-2.063.636-2.16.674-.675.213-.694.232-.772.87-.075.462-1.83 14.063-1.83 14.063L15.009 24l.927-21.166z";
const SNAP_D = "M12.206.793c.99 0 4.347.276 5.93 3.821.529 1.193.403 3.219.299 4.847l-.003.06c-.012.18-.022.345-.03.51.075.045.203.09.401.09.3-.016.659-.12 1.033-.301.165-.088.344-.104.464-.104.182 0 .359.029.509.09.45.149.734.479.734.838.015.449-.39.839-1.213 1.168-.089.029-.209.075-.344.119-.45.135-1.139.36-1.333.81-.09.224-.061.524.12.868l.015.015c.06.136 1.526 3.475 4.791 4.014.255.044.435.27.42.509 0 .075-.015.149-.045.225-.24.569-1.273.988-3.146 1.271-.059.091-.12.375-.164.57-.029.179-.074.36-.134.553-.076.271-.27.405-.555.405h-.03c-.135 0-.313-.031-.538-.074-.36-.075-.765-.135-1.273-.135-.3 0-.599.015-.913.074-.6.104-1.123.464-1.723.884-.853.599-1.826 1.288-3.294 1.288-.06 0-.119-.015-.18-.015h-.149c-1.468 0-2.427-.675-3.279-1.288-.599-.42-1.107-.779-1.707-.884-.314-.045-.629-.074-.928-.074-.54 0-.958.089-1.272.149-.211.043-.391.074-.54.074-.374 0-.523-.224-.583-.42-.061-.192-.09-.389-.135-.567-.046-.181-.105-.494-.166-.57-1.918-.222-2.95-.642-3.189-1.226-.031-.063-.052-.15-.055-.225-.015-.243.165-.465.42-.509 3.264-.54 4.73-3.879 4.791-4.02l.016-.029c.18-.345.224-.645.119-.869-.195-.434-.884-.658-1.332-.809-.121-.029-.24-.074-.346-.119-1.107-.435-1.257-.93-1.197-1.273.09-.479.674-.793 1.168-.793.146 0 .27.029.383.074.42.194.789.3 1.104.3.234 0 .384-.06.465-.105l-.046-.569c-.098-1.626-.225-3.651.307-4.837C7.392 1.077 10.739.807 11.727.807l.419-.015h.06z";
const META_D = "M6.915 4.03c-1.968 0-3.683 1.28-4.871 3.113C.704 9.208 0 11.883 0 14.449c0 .706.07 1.369.21 1.973a6.624 6.624 0 0 0 .265.86 5.297 5.297 0 0 0 .371.761c.696 1.159 1.818 1.927 3.593 1.927 1.497 0 2.633-.671 3.965-2.444.76-1.012 1.144-1.626 2.663-4.32l.756-1.339.186-.325c.061.1.121.196.183.3l2.152 3.595c.724 1.21 1.665 2.556 2.47 3.314 1.046.987 1.992 1.22 3.06 1.22 1.075 0 1.876-.355 2.455-.843a3.743 3.743 0 0 0 .81-.973c.542-.939.861-2.127.861-3.745 0-2.72-.681-5.357-2.084-7.45-1.282-1.912-2.957-2.93-4.716-2.93-1.047 0-2.088.467-3.053 1.308-.652.57-1.257 1.29-1.82 2.05-.69-.875-1.335-1.547-1.958-2.056-1.182-.966-2.315-1.303-3.454-1.303zm10.16 2.053c1.147 0 2.188.758 2.992 1.999 1.132 1.748 1.647 4.195 1.647 6.4 0 1.548-.368 2.9-1.839 2.9-.58 0-1.027-.23-1.664-1.004-.496-.601-1.343-1.878-2.832-4.358l-.617-1.028a44.908 44.908 0 0 0-1.255-1.98c.07-.109.141-.224.211-.327 1.12-1.667 2.118-2.602 3.358-2.602zm-10.201.553c1.265 0 2.058.791 2.675 1.446.307.327.737.871 1.234 1.579l-1.02 1.566c-.757 1.163-1.882 3.017-2.837 4.338-1.191 1.649-1.81 1.817-2.486 1.817-.524 0-1.038-.237-1.383-.794-.263-.426-.464-1.13-.464-2.046 0-2.221.63-4.535 1.66-6.088.454-.687.964-1.226 1.533-1.533a2.264 2.264 0 0 1 1.088-.285z";

// key → raw inner SVG markup (a nested 26×26 svg), embedded via set:html.
const FLOW_LOGOS: Record<string, string> = {
  meta: `<svg width="26" height="26" viewBox="0 0 24 24"><path fill="#0082FB" d="${META_D}"/></svg>`,
  google_ads: `<svg width="26" height="26" viewBox="0 0 48 48"><path fill="#FFC107" d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"/><path fill="#FF3D00" d="M6.306 14.691l6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"/><path fill="#4CAF50" d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238C29.211 35.091 26.715 36 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"/><path fill="#1976D2" d="M43.611 20.083H42V20H24v8h11.303c-.792 2.237-2.231 4.166-4.087 5.571l6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"/></svg>`,
  shopify: `<svg width="26" height="26" viewBox="0 0 24 24"><path fill="#95BF47" d="${SHOPIFY_D}"/></svg>`,
  tiktok: `<svg width="26" height="26" viewBox="0 0 24 24"><path fill="#25F4EE" transform="translate(-0.7 0.5)" d="${TIKTOK_D}"/><path fill="#FE2C55" transform="translate(0.7 -0.5)" d="${TIKTOK_D}"/><path fill="#010101" d="${TIKTOK_D}"/></svg>`,
  snapchat: `<svg width="26" height="26" viewBox="0 0 24 24"><rect width="24" height="24" rx="4" fill="#FFFC00"/><path fill="#FFF" stroke="#000" stroke-width="0.5" transform="translate(3 3) scale(0.75)" d="${SNAP_D}"/></svg>`,
  bosta: `<svg width="26" height="26" viewBox="0 0 24 24"><rect width="24" height="24" rx="6" fill="#E8173B"/><path fill="#fff" d="M12 5a4 4 0 0 1 4 4c0 2.5-2 4.5-4 6.5C10 13.5 8 11.5 8 9a4 4 0 0 1 4-4zm0 2.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM7 17h10v2H7z"/></svg>`,
};

// ── Month-over-month showcase: spend (bars, $k) + ROAS (line, ×) ──
const momRows = [
  { m: "Feb", spend: 32, roas: 3.1 },
  { m: "Mar", spend: 41, roas: 3.6 },
  { m: "Apr", spend: 38, roas: 4.0 },
  { m: "May", spend: 55, roas: 4.3 },
  { m: "Jun", spend: 61, roas: 4.8 },
  { m: "Jul", spend: 72, roas: 5.2 },
];
const MOM_W = 480, MOM_H = 220, MOM_PL = 14, MOM_PR = 14, MOM_PT = 16, MOM_PB = 30;
const momPlotW = MOM_W - MOM_PL - MOM_PR;
const momPlotH = MOM_H - MOM_PT - MOM_PB;
const momMaxSpend = Math.max(...momRows.map((r) => r.spend));
const momMinRoas = Math.min(...momRows.map((r) => r.roas)) - 0.6;
const momMaxRoas = Math.max(...momRows.map((r) => r.roas)) + 0.4;
const momStep = momPlotW / momRows.length;
const momBarW = momStep * 0.46;
const momBars = momRows.map((r, i) => {
  const cx = MOM_PL + momStep * i + momStep / 2;
  const h = (r.spend / momMaxSpend) * momPlotH;
  return { x: cx - momBarW / 2, y: MOM_PT + momPlotH - h, w: momBarW, h, cx, m: r.m };
});
const momLinePts = momBars.map((b, i) => {
  const y = MOM_PT + momPlotH - ((momRows[i].roas - momMinRoas) / (momMaxRoas - momMinRoas)) * momPlotH;
  return [Math.round(b.cx * 10) / 10, Math.round(y * 10) / 10];
});
const momLine = momLinePts.map((p, i) => `${i ? "L" : "M"}${p[0]} ${p[1]}`).join(" ");
const momBaseY = MOM_PT + momPlotH;
---

<Layout title="Every ad platform. Every store. One source of truth.">

  <!-- ============================== HERO ============================== -->
  <section class="relative overflow-hidden bg-white px-6 pt-16 pb-20 sm:pt-20">
    <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_70%_55%_at_50%_-15%,#e6e1fb,transparent)]"></div>

    <div class="mx-auto grid max-w-6xl items-center gap-14 lg:grid-cols-[1.05fr_1fr]">
      <!-- Copy -->
      <div class="text-center lg:text-left">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-xs font-semibold text-brand-700">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-500 opacity-70"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-600"></span>
          </span>
          Synced hourly · Live shareable dashboards
        </div>

        <h1 class="font-display text-[2.6rem] font-bold leading-[1.05] tracking-tight text-zinc-950 sm:text-6xl">
          Every ad platform.<br />
          Every store.<br />
          <span class="text-brand-600">One source of truth.</span>
        </h1>

        <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-zinc-500 lg:mx-0">
          AdFunnl pulls Meta, TikTok, Snapchat and Google — plus your Shopify and
          Salla revenue — into a single, always-fresh workspace. Build the reports
          you actually think in, and share live dashboards straight to your clients.
        </p>

        <div class="mt-9 flex flex-col items-center gap-4 sm:flex-row lg:justify-start justify-center">
          <a href={`${APP_URL}/signup`}
             class="w-full rounded-xl bg-brand-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-200 transition hover:bg-brand-700 sm:w-auto">
            Start free
          </a>
          <a href={`${APP_URL}/demo`}
             class="w-full rounded-xl border border-zinc-200 bg-white px-8 py-3.5 text-base font-semibold text-zinc-700 transition hover:bg-zinc-50 sm:w-auto">
            Book a demo
          </a>
        </div>

        <p class="mt-6 text-sm text-zinc-400">
          Trusted by brands and agencies running paid across four platforms and every store.
        </p>
      </div>

      <!-- Signature: the real Blended Overview (e-commerce) dashboard, in an
           app window. Anonymized demo data, reveals + count-up on load. -->
      <div class="hero-app relative mx-auto w-full max-w-md lg:max-w-none">
        <div class="relative overflow-hidden rounded-2xl border border-zinc-200/80 bg-white shadow-2xl shadow-brand-900/20 ring-1 ring-zinc-900/[0.04]">
          <!-- app top bar -->
          <div class="flex items-center gap-2 border-b border-zinc-100 bg-white px-3.5 py-2.5">
            <span class="flex h-5 w-5 items-center justify-center rounded-md bg-brand-600 text-[10px] font-bold text-white">A</span>
            <div class="flex items-center gap-1.5 text-[11px] font-semibold text-zinc-700">
              <span class="flex h-4 w-4 items-center justify-center rounded bg-brand-100 text-[8px] font-bold text-brand-700">BD</span>
              Brand Data
            </div>
            <span class="ms-1 hidden rounded-md border border-zinc-200 px-2 py-0.5 text-[10px] font-medium text-zinc-500 sm:inline-block">This month</span>
            <span class="hidden rounded-md border border-brand-200 bg-brand-50 px-2 py-0.5 text-[10px] font-medium text-brand-700 sm:inline-block">vs. last period</span>
            <div class="ms-auto flex items-center gap-1.5">
              <span class="hidden rounded-md border border-zinc-200 px-2 py-0.5 text-[10px] font-medium text-zinc-500 sm:inline-block">Share</span>
              <span class="rounded-md bg-brand-600 px-2 py-0.5 text-[10px] font-semibold text-white">+ Widget</span>
            </div>
          </div>

          <!-- dashboard body -->
          <div class="space-y-2.5 bg-zinc-50/50 p-3.5">
            <!-- Overview banner -->
            <div class="flex items-center justify-between rounded-lg bg-brand-600 px-3.5 py-2 shadow-sm shadow-brand-900/20">
              <span class="font-display text-sm font-bold tracking-tight text-white">Overview</span>
              <span class="inline-flex items-center gap-1.5 rounded-md bg-white/15 px-2 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-white">
                <span class="live-dot h-1.5 w-1.5 rounded-full bg-emerald-300"></span>Live
              </span>
            </div>

            <!-- per-platform metric rows -->
            {ovRows.map((row) => (
              <div class="flex items-stretch gap-2">
                <div class="flex w-7 shrink-0 items-center justify-center">
                  <span class="flex h-7 w-7 items-center justify-center overflow-hidden rounded-lg bg-white ring-1 ring-zinc-200/70 shadow-sm" title={row.name} aria-label={row.name}>
                    <PlatformIcon platform={row.key} class="h-5 w-5" />
                  </span>
                </div>
                <div class="grid flex-1 grid-cols-3 gap-1.5 sm:grid-cols-5">
                  {row.cells.map((c, i) => (
                    <div class={`rounded-lg border border-zinc-100 bg-white px-2 py-1.5 ${ovCols[i].hideSm ? "hidden sm:block" : ""}`}>
                      <p class="truncate text-[8px] font-medium uppercase tracking-wide text-zinc-400">{ovCols[i].label}</p>
                      <p class="mt-0.5 truncate font-display text-[12px] font-bold leading-tight text-zinc-900">
                        {ovCols[i].cur && <span class="text-[8px] font-semibold text-zinc-400">SAR </span>}{c[0]}
                      </p>
                      <p class={`mt-0.5 flex items-center gap-0.5 text-[8px] font-semibold ${c[3] ? "text-emerald-600" : "text-rose-500"}`}>
                        <span>{c[2] ? "▲" : "▼"}</span>{c[1]}%
                      </p>
                    </div>
                  ))}
                </div>
              </div>
            ))}

            <div class="border-t border-dashed border-zinc-200"></div>

            <!-- blended row (highlighted) -->
            <div class="flex items-stretch gap-2">
              <div class="flex w-7 shrink-0 items-center justify-center">
                <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-brand-600 text-white shadow-sm">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h18l-7 8v6l-4 2v-8z"/></svg>
                </span>
              </div>
              <div class="grid flex-1 grid-cols-3 gap-1.5 sm:grid-cols-5">
                {ovBlended.map((b, i) => (
                  <div class={`rounded-lg border border-brand-100 bg-brand-50/60 px-2 py-1.5 ${b.hideSm ? "hidden sm:block" : ""}`}>
                    <p class="truncate text-[8px] font-medium uppercase tracking-wide text-brand-400">{b.label}</p>
                    <p class="mt-0.5 truncate font-display text-[13px] font-bold leading-tight text-brand-900">
                      {b.cur && <span class="text-[8px] font-semibold text-brand-400">SAR </span>}
