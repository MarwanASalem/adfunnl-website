---
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.adfunnl.com";

const plans = [
  {
    name: "Starter",
    price: "$0",
    period: "forever",
    description: "For individuals and small teams getting started.",
    cta: "Get started free",
    href: `${APP_URL}/signup`,
    highlighted: false,
    features: [
      "1 workspace",
      "Up to 2 ad accounts",
      "Meta & TikTok integrations",
      "Basic dashboards",
      "7-day data history",
    ],
  },
  {
    name: "Pro",
    price: "$49",
    period: "per month",
    description: "For growing teams that need more data and integrations.",
    cta: "Start free trial",
    href: `${APP_URL}/signup`,
    highlighted: true,
    features: [
      "1 workspace",
      "Unlimited ad accounts",
      "All platform integrations",
      "Custom dashboards & widgets",
      "90-day data history",
      "Pulse monitoring & alerts",
      "Creative analysis",
      "Digest reports",
    ],
  },
  {
    name: "Agency",
    price: "$149",
    period: "per month",
    description: "For agencies managing multiple clients at scale.",
    cta: "Start free trial",
    href: `${APP_URL}/signup`,
    highlighted: false,
    features: [
      "Unlimited client workspaces",
      "Unlimited ad accounts",
      "All platform integrations",
      "White-label reports",
      "1-year data history",
      "Priority support",
      "Team member access",
    ],
  },
];
---

<Layout
  title="Pricing"
  description="Simple, transparent pricing for every team size."
>

  <section class="py-24 px-6">
    <div class="mx-auto max-w-6xl">

      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-zinc-950">
          Simple, transparent pricing
        </h1>
        <p class="mt-4 text-lg text-zinc-500 max-w-lg mx-auto">
          Start free. Upgrade when you need more. No hidden fees.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 items-start">
        {plans.map((plan) => (
          <div class={`rounded-2xl border p-8 flex flex-col gap-6 ${
            plan.highlighted
              ? "border-brand-500 bg-brand-600 text-white shadow-2xl shadow-brand-200 scale-[1.02]"
              : "border-zinc-200 bg-white"
          }`}>
            <div>
              <p class={`text-sm font-semibold ${plan.highlighted ? "text-brand-200" : "text-brand-600"}`}>
                {plan.name}
              </p>
              <div class="mt-2 flex items-end gap-1">
                <span class={`text-4xl font-extrabold tracking-tight ${plan.highlighted ? "text-white" : "text-zinc-950"}`}>
                  {plan.price}
                </span>
                <span class={`mb-1 text-sm ${plan.highlighted ? "text-brand-200" : "text-zinc-400"}`}>
                  / {plan.period}
                </span>
              </div>
              <p class={`mt-2 text-sm ${plan.highlighted ? "text-brand-100" : "text-zinc-500"}`}>
                {plan.description}
              </p>
            </div>

            <ul class="flex flex-col gap-2.5">
              {plan.features.map((f) => (
                <li class={`flex items-start gap-2.5 text-sm ${plan.highlighted ? "text-brand-50" : "text-zinc-600"}`}>
                  <span class={`mt-0.5 shrink-0 ${plan.highlighted ? "text-brand-200" : "text-brand-500"}`}>✓</span>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href={plan.href}
              class={`mt-auto block rounded-xl px-6 py-3 text-center text-sm font-semibold transition ${
                plan.highlighted
                  ? "bg-white text-brand-700 hover:bg-brand-50"
                  : "bg-brand-600 text-white hover:bg-brand-700"
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>

      <p class="mt-12 text-center text-sm text-zinc-400">
        All plans include a 14-day free trial. No credit card required to start.
      </p>

    </div>
  </section>

</Layout>
